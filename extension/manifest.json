{
  "manifest_version": 3,
  "name": "YouTube Music Island Bridge",
  "version": "0.1.0",
  "description": "Sends YouTube Music playback state to the local macOS island visualizer.",
  "permissions": [],
  "host_permissions": [
    "https://music.youtube.com/*",
    "http://127.0.0.1:47833/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
